{
  "name": "@cookbook/shared",
  "version": "1.0.0",
  "description": "Shared package of the cookbook app, contains shared DTOs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "compile": "npm run clean && npm test && npm run typecheck && npm run lint && npm run build",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --config ./jest.config.cjs --passWithNoTests"
  },
  "license": "ISC",
  "type": "module"
}
